#!/bin/bash
# Install VSCode extensions from extensions/vscode.txt (only when `code` exists).
set -euo pipefail

{{- if ne .role "desktop-fedora" }}
exit 0
{{- end }}

if ! command -v code >/dev/null 2>&1; then
    echo "[vscode] 'code' CLI not on PATH; skipping extension install."
    exit 0
fi

EXTENSIONS_FILE="{{ .chezmoi.sourceDir }}/extensions/vscode.txt"
[ -f "$EXTENSIONS_FILE" ] || exit 0

while IFS= read -r ext || [ -n "$ext" ]; do
    [[ -z "$ext" || "$ext" =~ ^# ]] && continue
    code --install-extension "$ext" --force
done < "$EXTENSIONS_FILE"

echo "[vscode] extensions installed."
