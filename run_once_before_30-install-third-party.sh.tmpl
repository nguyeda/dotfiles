#!/bin/bash
# Curl-installer based tools that aren't in the platform package manager:
#   - fnm (node version manager) — required by graphite, ccstatusline
#   - starship (prompt) — Linux non-Fedora has no native package
#   - uv (python pkg/runtime mgr) — Linux/devcontainer
set -euo pipefail

ROLE="{{ .role }}"

have() { command -v "$1" >/dev/null 2>&1; }

# ----------------------------------------------------------------------------
# fnm — install on every role (zshrc activates it conditionally)
# ----------------------------------------------------------------------------
if ! have fnm; then
{{- if eq .chezmoi.os "darwin" }}
    brew install fnm
{{- else }}
    curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
{{- end }}
fi

# ----------------------------------------------------------------------------
# starship — Linux outside Fedora needs the curl installer
# ----------------------------------------------------------------------------
{{- if and (ne .chezmoi.os "darwin") (ne (index .chezmoi.osRelease "id") "fedora") }}
if ! have starship; then
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi
{{- end }}

# ----------------------------------------------------------------------------
# uv — install for roles that ever touch Python
# ----------------------------------------------------------------------------
{{- if or (eq .role "desktop-mac") (eq .role "desktop-fedora") (eq .role "ec2") }}
if ! have uv; then
    curl -fsSL https://astral.sh/uv/install.sh | bash
fi
{{- end }}

# ----------------------------------------------------------------------------
# claude code CLI
# ----------------------------------------------------------------------------
{{- if or (eq .role "desktop-mac") (eq .role "desktop-fedora") (eq .role "pi") }}
if ! have claude; then
    curl -fsSL https://claude.ai/install.sh | bash
fi
{{- end }}

# ----------------------------------------------------------------------------
# opencode CLI
# ----------------------------------------------------------------------------
{{- if or (eq .role "desktop-mac") (eq .role "desktop-fedora") }}
if ! have opencode; then
{{- if eq .chezmoi.os "darwin" }}
    brew install anomalyco/tap/opencode
{{- else }}
    curl -fsSL https://opencode.ai/install | bash
{{- end }}
fi
{{- end }}

# ----------------------------------------------------------------------------
# jujutsu (jj) for Linux non-Fedora — release tarball
# ----------------------------------------------------------------------------
{{- if and (ne .chezmoi.os "darwin") (ne (index .chezmoi.osRelease "id") "fedora") }}
{{- if or (eq .role "ec2") (eq .role "pi") }}
if ! have jj; then
    case "$(uname -m)" in
        x86_64)  TARGET="x86_64-unknown-linux-musl" ;;
        aarch64) TARGET="aarch64-unknown-linux-musl" ;;
        *) echo "Unsupported arch for jj: $(uname -m)"; exit 0 ;;
    esac
    VERSION="$(curl -fsSL https://api.github.com/repos/jj-vcs/jj/releases/latest \
        | grep '"tag_name"' | sed 's/.*"v\(.*\)".*/\1/')"
    URL="https://github.com/jj-vcs/jj/releases/download/v${VERSION}/jj-v${VERSION}-${TARGET}.tar.gz"
    curl -fsSL "$URL" | sudo tar xz -C /usr/local/bin jj
fi
{{- end }}
{{- end }}

# ----------------------------------------------------------------------------
# graphite CLI (npm-installed, requires fnm + node)
# ----------------------------------------------------------------------------
{{- if eq .role "desktop-mac" }}
# Mac uses brew tap
if ! have gt; then
    brew install withgraphite/tap/graphite
fi
{{- end }}

echo "[third-party] done."
